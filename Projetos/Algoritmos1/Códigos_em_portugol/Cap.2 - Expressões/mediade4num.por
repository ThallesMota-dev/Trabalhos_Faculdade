Algoritmo "MediaQuatroNumeros"

Var
   n1, n2, n3, n4, media : Real

Início
   Escreva("Digite o 1º número: ")
   Leia(n1)

   Escreva("Digite o 2º número: ")
   Leia(n2)

   Escreva("Digite o 3º número: ")
   Leia(n3)

   Escreva("Digite o 4º número: ")
   Leia(n4)

   media <- (n1 + n2 + n3 + n4) / 4

   Escreva("Média: ", media)

Fimalgoritmo