Algoritmo Exemplo_Caso

var n1: inteiro;
início
    escreva("Entre com o valor a ser testado: ");
    leia(n1);
    caso n1 seja:
        1:
            escreva("Valor introduzido é válido: 1");
        5:
            escreva("Valor introduzido é válido: 5");
        10:
            escreva("Valor introduzido é válido: 10");
        default:
            escreva("Valor inválido: ", n1);
fim